DATABASE_URL=
AUTH_SECRET=
AUTH_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
INTERNAL_API_SECRET=
CRON_SECRET=
MESSAGING_ENABLED=false
# Secret local (HMAC) pour l'empreinte non réversible des fichiers de revue des
# dates de naissance. Facultatif : sans lui, review_id + source_row suffisent.
CANDIDATE_REVIEW_SECRET=
# Chemin LOCAL vers le fichier maître de revue (outil local privé
# preselections:review-ui). Ne jamais renseigner ici : la vraie valeur reste
# dans .env.local (ignoré). Hors dépôt, jamais committé.
PRESELECTION_REVIEW_FILE=
# Facultatif : chemin LOCAL de l'export source complet, pour reconstruire les
# colonnes import-ready (ex. city). Reste dans .env.local.
PRESELECTION_SOURCE_FILE=
